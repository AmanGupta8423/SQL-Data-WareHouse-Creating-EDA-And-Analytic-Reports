/*
================================
Create Database and Schemas
===============================
Script Purpose : This Script create a new database 
Warning Running this Script can drop the entire 'DataWarehouse' database if it exists
*/

USE master;

--check the existance of the DataWarehouse
IF EXISTS (SELECT * FROM sys.databases WHERE name = 'DataWarehouse')
BEGIN
	ALTER DATABASE DataWarehouse SET SINGLE_USER WITH ROLLBACK IMMEDIATE;
	DROP DATABASE DataWarehouse;
END;
GO
--Creating the DataWarehouse
CREATE DATABASE DataWarehouse;

--using the DataWarehouse
GO
USE DataWarehouse;

--Creating the Schemas 
GO
CREATE SCHEMA bronze;
GO
CREATE SCHEMA silver;
GO
CREATE SCHEMA gold;
GO
