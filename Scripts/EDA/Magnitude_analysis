--Magnitude Analysis
-------------------------------------------------------------
--customers by countries
SELECT country, COUNT(DISTINCT(customer_id)) AS 'total_customers' FROM gold.dim_customers
GROUP BY country
ORDER BY 'total_customers' DESC;

--customers by gender
SELECT gender, COUNT(DISTINCT(customer_id)) AS 'total_customers' FROM gold.dim_customers
GROUP BY gender
ORDER BY 'total_customers' DESC;

-- products by category
SELECT category, COUNT(DISTINCT(product_key)) AS 'total_products' FROM gold.dim_products
GROUP BY category
ORDER BY 'total_products' DESC;

--avg_price by category
SELECT t2.category, AVG(t1.price) AS average_price FROM gold.fact_sales AS t1
LEFT JOIN gold.dim_products AS t2
ON t1.product_key = t2.product_key
GROUP BY t2.category
ORDER BY average_price DESC;

--Avg Cost  by category
SELECT category ,AVG(cost) AS average_cost FROM gold.dim_products
GROUP BY category
ORDER BY average_cost DESC;

--revenue by category
SELECT t2.category, SUM(t1.sales_amount) AS total_revenue FROM gold.fact_sales AS t1
LEFT JOIN gold.dim_products AS t2
ON t1.product_key = t2.product_key
GROUP BY t2.category
ORDER BY total_revenue DESC;

--revenue by customers
SELECT c2.customer_id,SUM(c1.sales_amount) AS total_revenue FROM gold.fact_sales AS c1
LEFT JOIN gold.dim_customers AS c2
ON c1.customer_key = c2.customer_key
GROUP BY c2.customer_id
ORDER BY total_revenue DESC;

--quantity by country
SELECT c2.country,SUM(c1.quantity) AS total_quantity FROM gold.fact_sales AS c1
LEFT JOIN gold.dim_customers AS c2
ON c1.customer_key = c2.customer_key
GROUP BY c2.country
ORDER BY total_quantity DESC;

